# Normalize line endings across all platforms.
# All text files use LF in the repo; Git converts to native on checkout
# only if core.autocrlf is set on the contributor's machine.
* text=auto eol=lf

# Force binary handling for these so Git never line-ending-mangles them.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.avif   binary
*.ico    binary
*.svg    text eol=lf
*.pdf    binary
*.zip    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary

# Source files — explicit LF.
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.mjs    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sql    text eol=lf
*.py     text eol=lf
*.toml   text eol=lf
*.sh     text eol=lf
*.xml    text eol=lf
*.txt    text eol=lf
